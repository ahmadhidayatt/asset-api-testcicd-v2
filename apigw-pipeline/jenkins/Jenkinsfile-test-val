pipeline {
  agent any

  options {
    timestamps()
    timeout(time: 90, unit: 'MINUTES')
    disableConcurrentBuilds()
  }
  

  environment {
    COMMON_LIB   = "apigw-pipeline/bin/common.lib"
    TEST_RESULTS = "apigw-pipeline/test-results"
    APIGW_CREDS = credentials('apigw-cred')
  }

  stages {

    stage('Checkout') {
      steps { checkout scm }
    }

    stage('Load Properties') {
      steps {
        script {
          def props = readProperties file: 'apigw-pipeline/jenkins/jenkins.properties'

          env.API_PROJECT         = props['api_project']
          
          env.APIGATEWAY_URLS     = props['apigateway_urls']

          if (!env.APIGATEWAY_URLS) {
            error "apigateway_urls kosong!"
          }
        }
      }
    }

    stage('Deploy Sequential') {
      steps {
        script {

          def gateways = env.APIGATEWAY_URLS.split(',')
          def results = [:]

          for (int i = 0; i < gateways.size(); i++) {

            def gw = gateways[i].trim()
            def stageName = "GW-${i+1} (${gw})"

            stage(stageName) {

              try {

                stage("Precheck") {
                  withCredentials([usernamePassword(
                    credentialsId: 'apigw-cred',
                    usernameVariable: 'USER',
                    passwordVariable: 'PASS'
                  )]) {
                  sh """
                    source ${COMMON_LIB}

                    validate_gateway_up "${gw}" "${USER}" "${USER}"
                  """
                }

                def backupFile = ""

                stage("Backup") {
                  withCredentials([usernamePassword(
                    credentialsId: 'apigw-cred',
                    usernameVariable: 'USER',
                    passwordVariable: 'PASS'
                  )]) {
                    script {
                        def result = sh(
                            script: """
                              source ${COMMON_LIB}
                              backup_api "${API_PROJECT}" "${gw}" "${USER}" "${PASS}"
                            """,
                            returnStdout: true
                        ).trim()
                
                        def parts = result.split("\\|")
                        backupFile = parts[0]
                        appFile = parts[1]
                
                        echo "Backup file: ${backupFile}"
                        echo "App file: ${appFile}"
                    }
                }

                stage("Import") {
                  withCredentials([usernamePassword(
                    credentialsId: 'apigw-cred',
                    usernameVariable: 'USER',
                    passwordVariable: 'PASS'
                  )]) {
                  sh """
                    source ${COMMON_LIB}
                    import_api "${API_PROJECT}" "${gw}" "${USER}" "${PASS}"
                  """
                }

                stage("Postcheck") {
                  withCredentials([usernamePassword(
                    credentialsId: 'apigw-cred',
                    usernameVariable: 'USER',
                    passwordVariable: 'PASS'
                  )]) {
                  sh """
                    source ${COMMON_LIB}
                    validate_api_exists "${API_PROJECT}" "${gw}" "${USER}" "${PASS}"
                    validate_application "${API_PROJECT}" "${gw}" "${USER}" "${PASS}"
                  """
                }

                stage("Test") {
                  sh """
                    rm -rf ${TEST_RESULTS}
                    mkdir -p ${TEST_RESULTS}

                    docker run --rm \
                      -v \$PWD/apigw-pipeline:/etc/newman \
                      -w /etc/newman \
                      postman/newman:latest \
                      run tests/collection.json \
                      -e tests/environment.json \
                      --env-var httpInvokeUrl=${gw} \
                      --reporters cli,junit \
                      --reporter-junit-export test-results/result.xml
                  """
                }

                results[gw] = "SUCCESS"

              } catch (err) {

                echo "FAILED on ${gw}"
                results[gw] = "FAILED"

                stage("Rollback") {
                  withCredentials([usernamePassword(
                    credentialsId: 'apigw-cred',
                    usernameVariable: 'USER',
                    passwordVariable: 'PASS'
                  )]) {
                  sh """
                    source ${COMMON_LIB}
                    rollback_api "${backupFile}" "${gw}" "${USER}" "${PASS}"
                  """
                }

                error("STOP DEPLOY — failure on ${gw}")
              }
            }
          }

          stage("Summary") {
            echo "===== DEPLOYMENT SUMMARY ====="
            results.each { key, value ->
              echo "${key} → ${value}"
            }
          }
        }
      }
    }
  }

  post {
    success { echo "DEPLOY SUCCESS" }
    failure { echo "DEPLOY FAILED" }
  }
}
