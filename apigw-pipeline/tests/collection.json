{
  "info": {
    "name": "API Gateway Test",
    "_postman_id": "12345678-1234-1234-1234-123456789012",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "APIGW Health Check",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{httpInvokeUrl}}/rest/apigateway/health",
          "host": ["{{httpInvokeUrl}}"],
          "path": ["rest", "apigateway", "health"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Elasticsearch Cluster Health",
      "request": {
        "method": "GET",
        "auth": {
          "type": "basic",
          "basic": [
            { "key": "username", "value": "{{username}}" },
            { "key": "password", "value": "{{password}}" }
          ]
        },
        "url": {
          "raw": "{{esUrl}}/_cluster/health",
          "host": ["{{esUrl}}"],
          "path": ["_cluster", "health"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// pastikan request sukses dulu",
              "pm.test(\"Status 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// kalau gagal jangan lanjut parsing",
              "if (pm.response.code !== 200) {",
              "    console.error(\"Request failed, skip JSON parsing\");",
              "    return;",
              "}",
              "",
              "let json = pm.response.json();",
              "",
              "// ❗ HARD FAIL kalau RED",
              "pm.test(\"Cluster NOT RED\", function () {",
              "    pm.expect(json.status).to.not.eql(\"red\");",
              "});",
              "",
              "// ✅ hanya allow green / yellow",
              "pm.test(\"Cluster status acceptable\", function () {",
              "    pm.expect([\"green\", \"yellow\"]).to.include(json.status);",
              "});",
              "",
              "// ⚠️ warning kalau single node + yellow",
              "if (json.status === \"yellow\" && json.number_of_nodes === 1) {",
              "    console.warn(\"Single node cluster → expected yellow (no replica)\");",
              "}",
              "",
              "// ⚠️ warning kalau multi-node tapi yellow",
              "if (json.status === \"yellow\" && json.number_of_nodes > 1) {",
              "    console.warn(\"WARNING: Yellow on multi-node cluster\");",
              "}",
              "",
              "// sanity check",
              "pm.test(\"Cluster has nodes\", function () {",
              "    pm.expect(json.number_of_nodes).to.be.above(0);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}